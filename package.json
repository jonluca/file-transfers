{
  "name": "file-transfers",
  "version": "1.0.0",
  "private": true,
  "main": "main.ts",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "server:dev": "vite --config vite.server.config.ts",
    "server:start": "node dist/server/index.mjs",
    "server:prune-runtime-deps": "node scripts/prune-server-runtime-deps.mjs",
    "build": "vite build --config vite.server.config.ts",
    "heroku-build": "pnpm run build && node scripts/prune-server-runtime-deps.mjs",
    "start": "node dist/server/index.mjs",
    "dev": "expo start --dev-client",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "clean": "rm -rf android ios .expo dist node_modules",
    "ios": "expo run:ios",
    "mobile:prepare": "expo prebuild --clean",
    "mobile:dev": "expo run:ios --device",
    "mobile:android": "JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home expo run:android --device",
    "mobile:submit": "eas build --platform all --auto-submit --non-interactive",
    "macos:device": "tsx scripts/macos-transfer-device.ts",
    "android": "expo run:android",
    "auth:generate": "better-auth generate --config server/auth.ts --output server/db/schema/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:legacy": "tsx scripts/migrate-legacy-postgres.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix . && oxfmt --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@babel/core": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@better-auth/core": "1.6.5",
    "@better-auth/expo": "^1.6.5",
    "@better-auth/utils": "0.4.0",
    "@better-fetch/fetch": "1.1.21",
    "@dawidzawada/bonjour-zeroconf": "2.1.0",
    "@expo-google-fonts/geist": "^0.4.1",
    "@expo/log-box": "55.0.10",
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "15.1.1",
    "@hono/node-server": "^1.19.14",
    "@tanstack/query-core": "^5.99.1",
    "@tanstack/react-query": "^5.99.1",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.17",
    "better-auth": "^1.6.5",
    "better-call": "2.0.3",
    "burnt": "^0.13.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "^0.45.2",
    "expo": "^55.0.15",
    "expo-apple-authentication": "~55.0.13",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "^55.0.15",
    "expo-constants": "~55.0.14",
    "expo-crypto": "^55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-document-picker": "^55.0.13",
    "expo-font": "~55.0.6",
    "expo-iap": "^4.2.1",
    "expo-intent-launcher": "~55.0.12",
    "expo-keep-awake": "^55.0.6",
    "expo-linking": "~55.0.13",
    "expo-network": "^55.0.13",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "^55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "hono": "^4.12.14",
    "jose": "6.2.2",
    "kysely": "0.28.16",
    "lucide-react-native": "^1.8.0",
    "nanostores": "1.3.0",
    "postgres": "^3.4.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-nitro-http-server": "^1.6.1",
    "react-native-nitro-modules": "0.34.1",
    "react-native-purchases": "^10.0.1",
    "react-native-purchases-ui": "^10.0.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "4.24.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "0.7.2",
    "react-refresh": "^0.18.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uniwind": "^1.6.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@hono/vite-dev-server": "^0.25.1",
    "@types/babel__core": "^7",
    "@types/node": "^25.6.0",
    "@types/react-dom": "~19.1.11",
    "@typescript/native-preview": "7.0.0-dev.20260418.1",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "vite": "^8.0.8"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-screens"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "react-native-nitro-http-server"
    ]
  }
}
